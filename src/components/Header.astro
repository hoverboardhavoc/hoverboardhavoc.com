---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logo from '../assets/hoverboard-logo.jpg';
---

<header>
	<nav>
		<h2>
			<a href="/" class="brand">
				<Image src={logo} alt="" width={56} height={56} class="brand-logo" />
				<span class="brand-text flame-text">{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/hoverboardhavoc" target="_blank" rel="me noopener">
				<span class="sr-only">Hoverboard Havoc on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://www.youtube.com/@hoverboardhavoc" target="_blank" rel="me noopener">
				<span class="sr-only">Hoverboard Havoc on YouTube</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.493a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.353-.185-.92-.235-1.494l-.009-.104-.008-.104A31 31 0 0 1 .09 8.075V7.78c.002-.215.01-.958.063-1.778l.008-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c1.123-.302 5.288-.332 6.11-.335zM6.4 5.209v4.818l4.157-2.408z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
	}

	h2 a.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		font-weight: 700;
		letter-spacing: 0.01em;
	}
	.brand-logo {
		width: 56px;
		height: 56px;
		border-radius: 11px;
	}
	.brand-text {
		line-height: 1;
	}
	h2 a.brand:hover .brand-text {
		opacity: 0.85;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
	}
	nav a {
		padding: 1em 0.5em;
		white-space: nowrap;
		color: var(--text-muted);
		border-bottom: 3px solid transparent;
		text-decoration: none;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	.internal-links a:hover {
		color: var(--text);
	}
	nav a.active {
		text-decoration: none;
		color: var(--text);
		border-bottom-color: var(--neon);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links a {
		color: var(--text-muted);
	}
	.social-links a:hover {
		color: var(--neon-bright);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}
		.internal-links {
			flex-basis: 100%;
			justify-content: center;
			gap: 0.5em;
		}
		.internal-links a {
			padding: 0.5em 0.6em;
		}
	}
</style>
