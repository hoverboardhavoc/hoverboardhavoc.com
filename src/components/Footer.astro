<style>
	footer {
		padding: 2em 1em 6em 1em;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--text-muted);
	}
	.social-links a:hover {
		color: var(--neon-bright);
	}
