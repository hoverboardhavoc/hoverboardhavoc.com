---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const RECENT_COUNT = 8;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, RECENT_COUNT);

// Build a short plain-text excerpt from the start of each post's body.
function excerpt(body = '', max = 230) {
	const text = body
		.replace(/!\[[^\]]*\]\([^)]*\)/g, '') // images
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1') // links → link text
		.replace(/[#>*`_~]/g, '') // markdown punctuation
		.replace(/\s+/g, ' ')
		.trim();
	if (text.length <= max) return text;
	const cut = text.slice(0, max);
	return cut.slice(0, cut.lastIndexOf(' ')).trimEnd();
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="section-head">
				<h1 class="flame-text">From the blog</h1>
				<a class="see-all" href="/blog">See all blog entries →</a>
			</div>

			<ul class="feed">
				{
					posts.map((post) => (
						<li class={post.data.heroImage ? 'entry' : 'entry no-thumb'}>
							{post.data.heroImage && (
								<a class="thumb" href={`/blog/${post.id}/`}>
									<Image src={post.data.heroImage} alt="" width={480} height={360} />
								</a>
							)}
							<div class="entry-body">
								<h2 class="entry-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<p class="meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="excerpt">
									{excerpt(post.body)}
									<a class="read-more" href={`/blog/${post.id}/`}>
										…read more
									</a>
								</p>
							</div>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 900px;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		border-bottom: 2px solid var(--border);
		padding-bottom: 0.3em;
		margin-bottom: 1.5em;
	}
	.section-head h1 {
		font-size: 1.6em;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		margin: 0;
	}
	.see-all {
		white-space: nowrap;
		font-weight: 700;
	}

	.feed {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.entry {
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 1.5em;
		padding: 1.8em 0;
		border-bottom: 1px solid var(--border);
	}
	.entry:first-child {
		padding-top: 0;
	}
	.entry.no-thumb {
		grid-template-columns: 1fr;
	}
	.thumb {
		display: block;
	}
	.thumb img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 10px;
		border: 1px solid var(--border);
		transition: box-shadow 0.2s ease;
	}
	.thumb:hover img {
		box-shadow: 0 8px 30px rgba(255, 90, 0, 0.22), 0 0 0 1px rgba(47, 211, 240, 0.35);
	}
	.entry-title {
		font-size: 1.9em;
		line-height: 1.1;
		text-transform: uppercase;
		margin: 0 0 0.25em;
	}
	.entry-title a {
		color: var(--text);
		text-decoration: none;
	}
	.entry-title a:hover {
		color: var(--neon-bright);
	}
	.meta {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0 0 0.6em;
	}
	.excerpt {
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}
	.read-more {
		font-weight: 700;
		white-space: nowrap;
		color: var(--flame-2);
		text-decoration: none;
	}
	.read-more:hover {
		color: var(--flame-3);
	}

	@media (max-width: 720px) {
		.entry {
			grid-template-columns: 1fr;
			gap: 0.8em;
		}
		.section-head h1 {
			font-size: 1.3em;
		}
		.entry-title {
			font-size: 1.5em;
		}
	}
</style>
